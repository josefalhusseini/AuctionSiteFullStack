{
  "openapi": "3.0.4",
  "info": {
    "title": "AuctionApi",
    "version": "1.0"
  },
  "paths": {
    "/api/Auctions": {
      "get": {
        "tags": [
          "Auctions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Auctions"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAuctionDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAuctionDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAuctionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auctions/search": {
      "get": {
        "tags": [
          "Auctions"
        ],
        "parameters": [
          {
            "name": "title",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
